#!/usr/bin/env bash
# Test stub for vgs. With VGS_FIXTURE_DIR set, serves "<field>.<arg>" files
# (e.g. pv_name.pve, vg_name.local-lvm); otherwise fails exactly like a host
# without LVM, preserving the legacy disk-locality "degrade to none" path.
set -euo pipefail
[[ -n "${VGS_FIXTURE_DIR:-}" ]] || exit 1
field=""; arg=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        -o) field="$2"; shift 2 ;;
        -*) shift ;;
        *) [[ -n "$field" && -z "$arg" ]] && arg="$1"; shift ;;
    esac
done
f="$VGS_FIXTURE_DIR/${field}.${arg}"
[[ -f "$f" ]] && { cat "$f"; exit 0; }
exit 1
