#!/usr/bin/env bash
# Test stub for fio --output-format=json. Returns a minimal jobs[0] block.
# Bandwidth job (bs=1M) and IOPS job (bs=4k) are distinguished by args; values
# come from FIO_BW_RD_BPS/FIO_BW_WR_BPS and FIO_IOPS_RD/FIO_IOPS_WR.
set -euo pipefail
[[ -n "${FIO_CALL_LOG:-}" ]] && printf 'fio %s\n' "$*" >> "$FIO_CALL_LOG"
is_bw=0; case "$*" in *bs=1M*) is_bw=1 ;; esac
if [[ "$is_bw" == "1" ]]; then
    rd_bps="${FIO_BW_RD_BPS:-1500000000}"; wr_bps="${FIO_BW_WR_BPS:-1000000000}"
    printf '{"jobs":[{"read":{"bw_bytes":%s,"iops":0},"write":{"bw_bytes":%s,"iops":0}}]}\n' "$rd_bps" "$wr_bps"
else
    ir="${FIO_IOPS_RD:-200000}"; iw="${FIO_IOPS_WR:-100000}"
    printf '{"jobs":[{"read":{"bw_bytes":0,"iops":%s},"write":{"bw_bytes":0,"iops":%s}}]}\n' "$ir" "$iw"
fi
exit 0
