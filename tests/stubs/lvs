#!/usr/bin/env bash
# Test stub for lvs. With LVS_FIXTURE_DIR set:
#   lvs --noheadings -o vg_name <path>             -> cat "vg_name.<basename path>"
#   lvs ... -o lv_size,data_percent <vg>/<pool>    -> cat "lv_size,data_percent.<pool>"
#   lvs <vg>/<lv>                                  -> exit 0 iff "exists.<vg>_<lv>"
# Otherwise fails, preserving the legacy "no LVM" behavior.
set -euo pipefail
[[ -n "${LVS_FIXTURE_DIR:-}" ]] || exit 1
field=""; pos=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        -o) field="$2"; shift 2 ;;
        --units) shift 2 ;;   # value-taking (e.g. --units b)
        --noheadings|--nosuffix|-*) shift ;;
        *) pos+=("$1"); shift ;;
    esac
done
if [[ -n "$field" ]]; then
    base=$(basename "${pos[0]:-}")
    f="$LVS_FIXTURE_DIR/${field}.${base}"
    [[ -f "$f" ]] && { cat "$f"; exit 0; }
    exit 1
fi
tgt="${pos[0]:-}"
[[ -n "$tgt" && -f "$LVS_FIXTURE_DIR/exists.${tgt//\//_}" ]] && exit 0
exit 1
