#!/usr/bin/env bash
# Test stub for df --output=source <path>. Resolves <path> via DF_FIXTURE
# (lines: "<path> <source>"); unknown/unset -> a non-/dev source so host-OS
# detection simply finds nothing (safe default for non-throttle scenarios).
set -euo pipefail
path=""
for a in "$@"; do case "$a" in --output=*|-*) ;; *) path="$a" ;; esac; done
echo "source"
if [[ -n "${DF_FIXTURE:-}" && -n "$path" && -f "$DF_FIXTURE" ]]; then
    src=$(awk -v p="$path" '$1==p{print $2; exit}' "$DF_FIXTURE")
    echo "${src:--}"
else
    echo "-"
fi
exit 0
